    "test": "jest --runInBand",
    "worker": "ts-node src/scripts/workerEntrypoint.ts"
  },
  "dependencies": {
    "@sendgrid/mail": "^8.1.0",
    "amqplib": "^0.10.4",
    "aws-sdk": "^2.1530.0",
    "axios": "^1.6.0",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "crypto": "^1.0.1",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "googleapis": "^128.0.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^6.9.7",
    "otplib": "^12.0.1",
    "pdf-lib": "^1.17.1",
    "pdfmake": "^0.2.9",
    "pg": "^8.11.3",
