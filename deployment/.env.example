# ============================================================
# RISO HUB — .env.example
# Copy to .env and fill in all values before running.
# Never commit .env to version control.
# ============================================================

# ── Server ───────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000

# ── Database ──────────────────────────────────────────────────
# Local development:
DATABASE_URL=postgresql://risohub:password@localhost:5432/risohub
# Production (Render provides this automatically):
# DATABASE_URL=postgresql://...

# ── JWT ───────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_64_BYTE_HEX
JWT_REFRESH_SECRET=REPLACE_WITH_DIFFERENT_64_BYTE_HEX
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ── AWS S3 ────────────────────────────────────────────────────
AWS_REGION=eu-west-2
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
AWS_S3_BUCKET=risohub-files-production

# ── SendGrid ──────────────────────────────────────────────────
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxx
SENDGRID_FROM_EMAIL=noreply@risohome.co.uk
SENDGRID_FROM_NAME=RISO HOME

# ── Google Drive Sync ─────────────────────────────────────────
# Base64-encode your service account JSON:
# base64 -i service-account.json | tr -d '\n'
GOOGLE_SERVICE_ACCOUNT_JSON=base64encodedserviceaccountjson
GOOGLE_DRIVE_ROOT_FOLDER_ID=1BxiMVs0XRA5nFMdKvBdBZjgmUUqptlbs

# ── RabbitMQ (event bus) ──────────────────────────────────────
# Local: use Docker (see docker-compose.yml)
RABBITMQ_URL=amqp://localhost:5672
# Production: CloudAMQP free tier works for this workload
# RABBITMQ_URL=amqps://user:pass@hostname.cloudamqp.com/vhost

# ── HubSpot CRM ───────────────────────────────────────────────
# Private App token — requires crm.objects.contacts.read scope
HUBSPOT_ACCESS_TOKEN=pat-eu1-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ── EPC Register ─────────────────────────────────────────────
# Register at: https://epc.opendatacommunities.org/login (free)
EPC_API_EMAIL=your@email.com
EPC_API_KEY=your-epc-api-key

# ── BUS Eligibility ───────────────────────────────────────────
# Grant amounts in GBP — update if Ofgem changes the scheme
BUS_ASHP_GRANT_AMOUNT=7500
BUS_GSHP_GRANT_AMOUNT=7500

# ── Internal service token (for cron → API calls) ────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SERVICE_TOKEN=REPLACE_WITH_32_BYTE_HEX

# ── Firebase (push notifications — Phase 2) ───────────────────
# FIREBASE_PROJECT_ID=risohub
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk@risohub.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
